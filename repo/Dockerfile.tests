FROM node:20-bookworm-slim
# Debian-slim: avoids flaky Alpine/musl npm issues.
WORKDIR /workspace

COPY repo/backend/package*.json ./backend/
COPY repo/frontend/package*.json ./frontend/

RUN set -eu; \
    npm config set fetch-retries 5; \
    npm config set fetch-retry-mintimeout 20000; \
    npm config set fetch-retry-maxtimeout 120000; \
    for i in 1 2 3; do \
      rm -rf backend/node_modules; \
      (cd backend && npm install --no-audit --no-fund --loglevel=error) || true; \
      if [ -x backend/node_modules/.bin/vitest ]; then \
        echo "backend deps OK on attempt $i"; break; \
      fi; \
      echo "backend attempt $i missing devDeps; retrying"; sleep 5; \
    done; \
    test -x backend/node_modules/.bin/vitest; \
    for i in 1 2 3; do \
      rm -rf frontend/node_modules; \
      (cd frontend && npm install --legacy-peer-deps --no-audit --no-fund --loglevel=error) || true; \
      if [ -x frontend/node_modules/.bin/vitest ]; then \
        echo "frontend deps OK on attempt $i"; break; \
      fi; \
      echo "frontend attempt $i missing devDeps; retrying"; sleep 5; \
    done; \
    test -x frontend/node_modules/.bin/vitest

COPY repo/backend ./backend
COPY repo/frontend ./frontend
COPY docs ./docs

# Runs backend + frontend tests with coverage. Text summary is emitted to
# stdout; lcov/html are persisted under each package's ./coverage folder.
CMD ["sh", "-c", "cd backend && npm run test:coverage && cd ../frontend && npm run test:coverage"]
