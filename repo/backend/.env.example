# Server
PORT=4000

# CORS allowed origins (comma-separated for multiple)
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:8081

# MySQL database connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=neighborhoodpickup
DB_CONNECTION_LIMIT=10

# Session authentication
SESSION_SECRET=change-this-in-local-env
SESSION_TTL_HOURS=12

# Account lockout policy (failed login attempts)
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_MINUTES=15

# Include stack traces in unhandled error logs (disable in production)
LOG_UNHANDLED_ERROR_INCLUDE_STACK=true

# Behavior telemetry retention scheduler interval in minutes (0 = disabled)
BEHAVIOR_RETENTION_RUN_INTERVAL_MINUTES=0

# AES encryption key for sensitive data at rest (must change in production)
DATA_ENCRYPTION_KEY=local-dev-data-encryption-key-change-me
