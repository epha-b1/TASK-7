{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "ts-node --transpile-only src/db/migrate.ts up",
    "db:migrate:down": "ts-node --transpile-only src/db/migrate.ts down",
    "db:seed": "ts-node --transpile-only src/db/seed.ts"
  },
  "dependencies": {
    "@types/swagger-ui-express": "^4.1.8",
    "argon2": "^0.44.0",
    "cors": "^2.8.5",
    "debug": "^4.3.7",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "mime-db": "^1.53.0",
    "mysql2": "^3.15.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@noble/hashes": "^1.8.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.9.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.38.0",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
